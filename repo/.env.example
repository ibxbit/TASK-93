# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# Tracing level: error | warn | info | debug | trace
# Scoped example: motorsport_backend=debug,rocket=warn
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container; maps to the `motorsport_data` Docker volume.
DATABASE_URL=sqlite:///app/data/motorsport.db

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key: base64-encoded 32 random bytes.
# Generate with:  openssl rand -base64 32
# NEVER commit the real key.  Store it in a secrets manager or Docker secret.
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ── Backup ────────────────────────────────────────────────────────────────────
# Directory where nightly SQLite backup files are stored.
# Maps to the `motorsport_backups` Docker volume inside the container.
BACKUP_DIR=/app/backups

# Number of nightly backup files to retain before rotation (default: 7).
BACKUP_RETAIN_DAYS=7
