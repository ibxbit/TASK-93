# Coverage.py configuration for the motorsport-backend Python test suite.
#
# Measures line + branch coverage over the Python test code
# (unit_tests/ and API_tests/) — the Rust backend is exercised by these tests
# but lives outside this tool's scope.  Coverage artifacts are written under
# coverage_reports/ so they can be picked up by CI.

[run]
branch = True
source =
    unit_tests
    API_tests
    conftest.py
omit =
    */__pycache__/*
    */.pytest_cache/*

[report]
# Show lines that were never executed so gaps are visible at a glance.
show_missing = True
# Two decimals on the coverage percentage.
precision = 2
skip_empty = True
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:

[html]
directory = coverage_reports/html

[xml]
output = coverage_reports/coverage.xml
